{
  "name": "openant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n service,client -c blue,green \"pnpm --filter ./service dev\" \"pnpm --filter ./client dev\"",
    "build": "pnpm --filter ./service build && pnpm --filter ./client build",
    "lint": "pnpm --filter ./service typecheck && pnpm --filter ./client lint",
    "test": "pnpm --filter ./service test"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
